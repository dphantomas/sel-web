datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  phone         String?
  addressLine1  String?
  addressLine2  String?
  zipCode       String?
  country       String?
  sparkName     String?
  image         String?
  role          Role      @default(Guest)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  unlockedCourses UserCourseAccess[]
  progress        Progress[]
}

enum Role {
  Guest
  Participante
  Transmisor
  Admin
}

enum CourseType {
  Curso
  Taller
  Iniciacion
  Activacion
  Retiro
}

enum Modality {
  Presencial
  Virtual
}

enum Synchronicity {
  Sincronico
  Asincronico
}

model Course {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String?
  description      String?
  type             CourseType
  durationDays     Int?
  modality         Modality      @default(Virtual)
  synchronicity    Synchronicity @default(Asincronico)
  published        Boolean       @default(false)
  image            String?

  modules         Module[]
  instances       CourseInstance[]
  usersWithAccess UserCourseAccess[]
  resources       Resource[] // Resources attached to the whole course

  // Pre-requisitos a nivel de Curso
  prerequisites   Course[] @relation("CoursePrerequisites")
  prerequisiteFor Course[] @relation("CoursePrerequisites")

  // Como pre-requisito para una instancia específica
  prerequisiteForInstances CourseInstance[] @relation("InstancePrerequisiteCourses")
}

model CourseInstance {
  id        String    @id @default(cuid())
  courseId  String
  startDate DateTime
  endDate   DateTime?
  price     Float?
  location  String?

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources Resource[]

  // Pre-requisitos específicos de esta instancia
  prerequisites Course[] @relation("InstancePrerequisiteCourses")
}

model UserCourseAccess {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  grantedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int      @default(0)
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

model Lesson {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique
  content   String? // Contenido markdown o html
  videoUrl  String? // URL de video (Vimeo/YouTube)
  order     Int        @default(0)
  moduleId  String
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress  Progress[]
  resources Resource[] // Resources attached specifically to a lesson
}

model Resource {
  id             String  @id @default(cuid())
  name           String
  type           String // AUDIO, PDF, etc.
  cloudflareKey  String
  isDownloadable Boolean @default(false)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  courseInstanceId String?
  courseInstance   CourseInstance? @relation(fields: [courseInstanceId], references: [id], onDelete: Cascade)

  overridesResourceId String?
  overridesResource   Resource?  @relation("ResourceOverrides", fields: [overridesResourceId], references: [id], onDelete: SetNull)
  overriddenBy        Resource[] @relation("ResourceOverrides")
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}
